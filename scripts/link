#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/cjavdev/believe-go,github.com/stainless-sdks/believe-go"

REPLACEMENT="${1:-"../believe-go"}"
echo "==> Replacing Go SDK with $REPLACEMENT"
go mod edit -replace github.com/cjavdev/believe-go="$REPLACEMENT"
go mod tidy -e
